{
  "name": "folify",
  "version": "0.1.0",
  "description": "Generate polished portfolio HTML/CSS and PDF from structured JSON",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
